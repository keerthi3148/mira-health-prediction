# Google Gemini API Key for detailed conversational diagnostic remarks.
# Obtain a key from: https://aistudio.google.com/
# If left blank, MIRA will use the local Scikit-learn RandomForest model & clinical guidelines.
GEMINI_API_KEY=your_gemini_api_key_here
